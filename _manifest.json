{
  "manifest_version": 2,
  "version": "0.1.0",
  "name": "maibot-maid-adapter",
  "description": "MaiBot 女仆适配器，用于接入 TouhouLittleMaid 和 MaidBridge WebSocket",
  "author": {
    "name": "litroenade",
    "url": "https://github.com/litroenade"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/litroenade/maibot-maid-adapter",
    "homepage": "https://github.com/litroenade/maibot-maid-adapter",
    "documentation": "https://github.com/litroenade/maibot-maid-adapter",
    "issues": "https://github.com/litroenade/maibot-maid-adapter/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "aiohttp",
      "version_spec": ">=3.9"
    }
  ],
  "capabilities": [
    "api.call",
    "api.list",
    "llm.generate"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN",
      "en-US"
    ]
  },
  "id": "maibot-maid-adapter"
}
